Package: PDSIR
Title: An implementation of the piece-wise decoupled SIR process
Version: 0.0.0.9001
Authors@R: c(
    person(given = "Raphael",
           family = "Morsomme",
           role = c("aut", "cre"),
           email = "raphael.morsomme@duke.edu"),
    person(given = "Jason",
           family = "Xu",
           role = "ctb",
